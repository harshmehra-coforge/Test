# Environment Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/wealth_management?schema=public"
DATABASE_POOL_SIZE=20
DATABASE_TIMEOUT=30000

# Redis Configuration
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""
REDIS_DB=0

# Kafka Configuration
KAFKA_BROKERS="localhost:9092"
KAFKA_CLIENT_ID="wealth-management-platform"
KAFKA_GROUP_ID="wealth-management-group"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="4h"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Encryption Configuration
ENCRYPTION_KEY="your-32-character-encryption-key-here"
ENCRYPTION_ALGORITHM="aes-256-gcm"

# MFA Configuration
MFA_ISSUER="Wealth Management Platform"
MFA_WINDOW=2

# External API Configuration
NORTHERN_TRUST_API_URL="https://api.northerntrust.com"
NORTHERN_TRUST_API_KEY="your-northern-trust-api-key"
NORTHERN_TRUST_CLIENT_ID="your-client-id"
NORTHERN_TRUST_CLIENT_SECRET="your-client-secret"

MARKET_DATA_API_URL="https://api.marketdata.com"
MARKET_DATA_API_KEY="your-market-data-api-key"

OFAC_API_URL="https://api.treasury.gov/ofac"
OFAC_API_KEY="your-ofac-api-key"

CREDIT_BUREAU_API_URL="https://api.creditbureau.com"
CREDIT_BUREAU_API_KEY="your-credit-bureau-api-key"

# Notification Configuration
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@company.com"
EMAIL_PASSWORD="your-email-password"
EMAIL_FROM="noreply@wealthmanagement.com"

TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# Logging Configuration
LOG_LEVEL="info"
LOG_FILE="logs/app.log"
LOG_MAX_SIZE="10m"
LOG_MAX_FILES="5"

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN="http://localhost:3000,https://app.wealthmanagement.com"
CORS_CREDENTIALS=true

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_SECRET="your-session-secret-change-in-production"
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE="strict"

# Monitoring Configuration
PROMETHEUS_PORT=9090
HEALTH_CHECK_INTERVAL=30000

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH="uploads/"
ALLOWED_FILE_TYPES="pdf,jpg,jpeg,png,doc,docx"

# Compliance Configuration
AML_THRESHOLD_AMOUNT=10000
OFAC_SCREENING_ENABLED=true
COMPLIANCE_REVIEW_THRESHOLD=1000000
SAR_FILING_THRESHOLD=5000

# Business Rules Configuration
MIN_ACCOUNT_BALANCE=250000
MAX_DAILY_TRANSFER_LIMIT=10000000
REBALANCING_THRESHOLD=0.05
GOAL_ALIGNMENT_MIN_SCORE=6

# Cache Configuration
CACHE_TTL_MARKET_DATA=300
CACHE_TTL_PORTFOLIO_DATA=3600
CACHE_TTL_CLIENT_DATA=1800
CACHE_TTL_SESSION_DATA=14400